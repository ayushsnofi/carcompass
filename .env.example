DATABASE_URL="file:./dev.db"

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY="your-openrouter-api-key"
# Model slug from https://openrouter.ai/models (e.g. google/gemini-2.5-pro)
# Free models (e.g. meta-llama/...:free) are often rate-limited — add credits or use a paid model
OPENROUTER_MODEL="google/gemini-2.0-flash-001"
# Optional second model tried after retries on the primary
OPENROUTER_FALLBACK_MODEL="google/gemini-2.0-flash-001"
OPENROUTER_MAX_RETRIES="3"
OPENROUTER_JSON_MODE="true"
OPENROUTER_SITE_URL="http://localhost:3000"
OPENROUTER_APP_NAME="CarDekho"

LLM_MODE="live"
# Auto-fallback to rule-based mock when quota/rate-limited
LLM_FALLBACK_ON_ERROR="true"
# Set LLM_MODE=mock to skip OpenRouter entirely (tests / offline)

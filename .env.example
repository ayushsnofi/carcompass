# Prisma Postgres / Vercel Postgres — copy from dashboard
# Use db.prisma.io for both (NOT pooled.db.prisma.io) for local migrate/seed
DATABASE_URL="postgres://USER:PASSWORD@db.prisma.io:5432/postgres?sslmode=require"
DIRECT_URL="postgres://USER:PASSWORD@db.prisma.io:5432/postgres?sslmode=require"

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY="your-openrouter-api-key"
OPENROUTER_MODEL="google/gemini-2.0-flash-001"
OPENROUTER_FALLBACK_MODEL="qwen/qwen-2.5-7b-instruct:free"
OPENROUTER_MAX_RETRIES="3"
OPENROUTER_JSON_MODE="true"
OPENROUTER_SITE_URL="http://localhost:3000"
OPENROUTER_APP_NAME="CarDekho"

LLM_MODE="live"
LLM_FALLBACK_ON_ERROR="true"
